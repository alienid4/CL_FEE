# Python / test cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.venv-win/
venv/
env/

# Runtime data
data/*.db
data/*.sqlite
data/*.sqlite3
logs/
*.log

# C1 生成物（由 snapshot.py 產生，不進版控）
CURRENT_STATE.md

# C1 會議 demo 稿（內含示範用假密鑰，是給人看的 meeting 稿，不進版控）
DEMO_會議腳本.md

# Local environment / secrets
.env
.env.*
!.env.example

# OneDrive / Windows noise
desktop.ini
Thumbs.db
~$*
*.tmp
*.bak

# Source business documents and sensitive samples.
# Keep derived Markdown notes in docs/, but do not version raw source files by default.
DOC/
*.pdf
*.docx
*.pptx
*.xlsx
*.xls
*.xlsm
*.csv
*.tsv

# 簡報二進位／圖檔／舊草稿：走 OneDrive，不進 git（只版控 PPT/*.md 文字稿）
PPT/圖/
PPT/_舊版草稿/

# 自主迴圈（.project/loop.py）的揮發產出：報告是生成物、backlog 是執行時佇列
.project/run_report.md
.project/backlog.json

# 根目錄舊檔歸檔：git 歷史已保留被刪原檔，備份不重複進版控
archive/

# Archives and generated bundles
*.zip
*.rar
*.7z
project-baseline-kit_v*/

# Frontend / package caches if added later
node_modules/
dist/
build/
