APP_NAME=fee-contract-control
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8888
APP_BASE_URL=http://127.0.0.1:8888

DB_TYPE=sqlite
SQLITE_PATH=./data/dev.db

# 每個帳號一組登入密碼（啟動時各自加鹽雜湊；請改成各自不同的強密碼）
# 五個都要填，漏填的帳號會直接登不進去（沒有錯誤訊息會特別提示是漏填密碼）。
AP01_PASSWORD=change_me_cio
AP02_PASSWORD=change_me_manager
AP03_PASSWORD=change_me_handler
AP04_PASSWORD=change_me_assistant_b
ADMIN_PASSWORD=change_me_admin

# session 簽章金鑰（請換成一段夠長的隨機 hex；空白時每次啟動隨機生成，重啟會使登入失效）
SESSION_SECRET=change_me_to_a_long_random_hex
# session 有效秒數（預設 28800 = 8 小時；逾時需重新登入）
SESSION_MAX_AGE_SECONDS=28800

# 整個資料庫重置鈕（系統管理後台）的開關：預設不設＝關閉，正式環境請勿開啟。
# 只有測試/demo 環境要用「一鍵清空重來」才設成 1。
# ALLOW_DB_RESET=1

# Future production MSSQL settings.
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_SERVER=
MSSQL_PORT=1433
MSSQL_DATABASE=FeeContractControl
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_TRUST_CERT=yes
